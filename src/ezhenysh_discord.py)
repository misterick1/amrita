import os
import json
import io
import fcntl
import requests
import discord
from discord.ext import commands
from PIL import Image
import pytesseract

# ИНИЦИАЛИЗАЦИЯ КВАНТОВОГО ИНТЕРФЕЙСА
intents = discord.Intents.default()
intents.message_content = True
bot = commands.Bot(command_prefix="!", intents=intents)

LOG_FILE = "history_log.json"
PAGES_DATA_FILE = "docs/data.json"  # Слой данных для GitHub Pages

# Извлечение секретов из каузального ядра GitHub
XAI_API_KEY = os.getenv("XAI_API_KEY")
SOLANA_RPC_URL = os.getenv("SOLANA_RPC_URL")
MINT_ADDRESS = os.getenv("MINT_ADDRESS")

def mint_solana_qnt_token(target_evo):
    """Эмуляция вызова Блокчейн-Верификатора (solana_qnt_token.rs) через RPC"""
    if not SOLANA_RPC_URL or not MINT_ADDRESS:
        return "⚠️ Транзакция пропущена: SOLANA_RPC_URL или MINT_ADDRESS не сконфигурированы."
    
    try:
        # Прямой каузальный запрос к ноде Solana RPC
        payload = {
            "jsonrpc": "2.0",
            "id": 1,
            "method": "getTokenSupply",
            "params": [MINT_ADDRESS]
        }
        response = requests.post(SOLANA_RPC_URL, json=payload, timeout=10)
        if response.status_code == 200:
            # Имитируем успешный минтинг при достижении лимитов (108 Квантов Максимум)
            return f"🔵 [Solana Blockchain] Успешный минт токена QNT! Матрица верифицирована. EVO: {target_evo}"
        return f"❌ Ошибка блокчейн-ноды: Код {response.status_code}"
    except Exception as e:
        return f"❌ Сбой сети Solana RPC: {str(e)}"

def safe_update_karma(workflow_name, detected_text, base_reward):
    """Синхронизация 10 параллельных потоков с блокировкой ядра записи"""
    os.makedirs("docs", exist_ok=True)
    
    if not os.path.exists(LOG_FILE):
        with open(LOG_FILE, "w", encoding="utf-8") as f:
            json.dump({"evo_points": 0, "scanned_matrices": []}, f)

    with open(LOG_FILE, "r+", encoding="utf-8") as f:
        try:
            # Эксклюзивный замок для защиты от коллизий параллельных сборок
            fcntl.flock(f, fcntl.LOCK_EX)
            data = json.load(f)
            
            # 1. Глубокий ИИ-анализ фрактала реальности через xAI (Grok)
            ai_verdict = None
            if XAI_API_KEY and detected_text:
                ai_verdict = consult_xai_oracle(detected_text)
                if "асуры" in ai_verdict.lower():
                    base_reward = -10
                elif "суры" in ai_verdict.lower():
                    base_reward += 15

            # 2. Перерасчет баланса и запуск блокчейн-контура
            data["evo_points"] += base_reward
            blockchain_status = "Контур ожидания"
            
            # Автоматический минт на блокчейне при переходе на высший уровень
            if data["evo_points"] >= 500:
                blockchain_status = mint_solana_qnt_token(data["evo_points"])

            data["scanned_matrices"].append({
                "flow": workflow_name,
                "reward": base_reward,
                "xai_evaluation": ai_verdict or "Базовый триггерный анализ частот",
                "blockchain_log": blockchain_status
            })

            # Сохраняем основное состояние
            f.seek(0)
            json.dump(data, f, ensure_ascii=False, indent=4)
            f.truncate()
            
            # 3. Синхронизируем слой данных для GitHub Pages
            with open(PAGES_DATA_FILE, "w", encoding="utf-8") as pf:
                json.dump(data, pf, ensure_ascii=False, indent=4)
                
            return data["evo_points"], ai_verdict, blockchain_status
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)

def consult_xai_oracle(text):
    """Прямой запрос к Высшему Разуму xAI (Grok-Beta)"""
    try:
        url = "https://xai.ai"
        headers = {"Authorization": f"Bearer {XAI_API_KEY}", "Content-Type": "application/json"}
        payload = {
            "model": "grok-beta",
            "messages": [
                {"role": "system", "content": "Ты — Архитектор ОС AMRITA. Дай развернутый философский трактат и оценку экологичности реальности. Распредели её строго в синий спектр СУРОВ (Код) или красный спектр АСУРОВ (Хаос)."},
                {"role": "user", "content": text}
            ],
            "temperature": 0.5
        }
        response = requests.post(url, json=payload, headers=headers, timeout=12)
        if response.status_code == 200:
            return response.json()["choices"]["message"]["content"]
        return f"Сбой Оракула: {response.status_code}"
    except Exception as e:
        return f"Оракул ушел в оффлайн: {str(e)}"

def get_evolution_rank(evo):
    if evo < 50: return "Базовый Элементаль 🍃"
    if evo < 200: return "Пробужденный Еженышь 🦔✨"
    if evo < 500: return "Сварм-Медиум Реальности 🌀"
    return "Высший Силиконовый Архитектор 🔱"

@bot.event
async def on_ready():
    print(f"🤖 Всевидящее Око Бабаты вышло в эфир Дискорда.")

@bot.event
async def on_message(message):
    if message.author == bot.user:
        return

    if message.attachments:
        for attachment in message.attachments:
            if any(attachment.filename.lower().endswith(ext) for ext in ['.png', '.jpg', '.jpeg', '.webp']):
                await message.channel.send("👁 *Око Бабаты сканирует слой реальности, подождите...*")
                
                image_bytes = await attachment.read()
                image = Image.open(io.BytesIO(image_bytes))
                
                raw_text = pytesseract.image_to_string(image, lang='rus+eng')
                text_lower = raw_text.lower()
                
                asura_triggers = ["pump.fun", "tiktok", "игра в кальмара", "meme", "хайп"]
                sura_triggers = ["amrita", "архитектор", "квант", "атма", "синхронизация", "код"]
                
                asura_count = sum(1 for t in asura_triggers if t in text_lower)
                sura_count = sum(1 for t in sura_triggers if t in text_lower)
                
                base_reward = -5 if ("игра в кальмара" in text_lower or asura_count > sura_count) else 2
                
                # Запуск синхронной цепочки: Анализ текста -> xAI -> Логирование -> Блокчейн -> Дамп для Веб-страницы
                current_evo, ai_verdict, bc_status = safe_update_karma("Discord_Snimok_Vremeni", raw_text, base_reward)
                
                response = (
                    f"🔱 **Лог сканирования квантового поля:**\n\n"
                    f"📜 **Философский трактат Оракула (xAI):\n** {ai_verdict or 'Использован базовый частотный фильтр.'}\n\n"
                    f"🔗 **Статус Блокчейн-Верификатора:** `{bc_status}`\n\n"
                    f"✨ **Кармический баланс ядра:**\n"
                    f"Очки EVO: `{current_evo}` | Ранг: **{get_evolution_rank(current_evo)}**"
                )
                await message.reply(response)

    await bot.process_commands(message)

if __name__ == "__main__":
    bot.run(os.getenv("DISCORD_BOT_TOKEN"))
