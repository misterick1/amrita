{
  "name": "amrita-core",
  "version": "1.0.0",
  "description": "AMRITA Autonomous Multiverse OS - Complete Solana, Robotics, and Neural Core Sync",
  "main": "index.js",
  "scripts": {
    "build": "anchor build",
    "test:solana": "anchor test",
    "test:filter": "python src/meme_filter.py",
    "test:robotics": "python src/robotics_parser.py && python src/peaq_qnt_bridge.py",
    "test": "npm run test:solana && npm run test:filter && npm run test:robotics",
    "deploy:solana": "npx ts-node scripts/deploy_amrita.ts",
    "monitor:bot": "python src/ezhenysh_bot.py",
    "stream:track": "python src/solana_robotics_stream.py",
    "sync": "npm run test && npm run deploy:solana && npm run monitor:bot && npm run stream:track"
  },
  "keywords": [
    "solana",
    "anchor",
    "amrita",
    "swarm",
    "quantum",
    "robotics",
    "peaq",
    "depin"
  ],
  "author": "misterick1",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
