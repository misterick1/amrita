import os
import re
import glob
import json
import pytesseract
from PIL import Image
from telebot import TeleBot

# Инициализация переменных окружения
TG_TOKEN = os.getenv("TELEGRAM_BOT_TOKEN")
RUN_ID = os.getenv("GITHUB_RUN_ID")
XAI_KEY = os.getenv("XAI_API_KEY")

LOG_FILE = "history_log.json"

def load_causal_memory():
    """Загрузка вечной памяти контура, чтобы ничего не забывать при перезапусках"""
    if os.path.exists(LOG_FILE):
        try:
            with open(LOG_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            return {"chapters_count": 0, "logs": [], "system_state": "READY"}
    return {"chapters_count": 0, "logs": [], "system_state": "READY"}

def save_causal_memory(memory_data):
    """Фиксация параметров в вечный лог"""
    try:
        with open(LOG_FILE, "w", encoding="utf-8") as f:
            json.dump(memory_data, f, ensure_ascii=False, indent=4)
    except Exception as e:
        print(f"❌ Ошибка записи каузального трекера памяти: {e}")

def analyze_and_save():
    if not TG_TOKEN:
        print("❌ Critical Error: TELEGRAM_BOT_TOKEN is missing!")
        return

    bot = TeleBot(TG_TOKEN)
    memory = load_causal_memory()
    
    print("🌀 Connecting to Telegram matrix with CORS-bypass protocols...")
    try:
        # Сдвиг offset=-1 гарантирует забор самого последнего скриншота реальности
        updates = bot.get_updates(offset=-1, timeout=20)
    except Exception as e:
        print(f"⚠️ Telegram poll failed: {e}")
        updates = None

    if not updates:
        print("⚠️ No fresh screenshots found in the matrix network.")
        raw_text = "Фоновый лог фиксации Великой Пустоты."
    else:
        # Извлекаем последнее сообщение
        message = updates[0].message if isinstance(updates, list) else updates.message
        
        if message and message.photo:
            file_info = bot.get_file(message.photo[-1].file_id)
            # Принудительный стриминг файла в обход сетевых прокси-ограничений
            downloaded_file = bot.download_file(file_info.file_path)
            
            with open("temp_slice.png", "wb") as f:
                f.write(downloaded_file)
            
            print("👁 Running Tesseract OCR Matrix Analysis...")
            try:
                raw_text = pytesseract.image_to_string(Image.open("temp_slice.png"), lang="rus+eng")
            except Exception as ocr_err:
                print(f"❌ OCR failure: {ocr_err}")
                raw_text = "Ошибка сканирования физического слоя."
            finally:
                if os.path.exists("temp_slice.png"):
                    os.remove("temp_slice.png")
        else:
            raw_text = "Текстовый импульс без визуальной фиксации."

    detected_context = []
    # Добавлен ключ '300' и 'xai' для детекции сбоя хаба Бабаты
    if re.search(r'(300|рубеж|стазис|отдых|финансы|xai|блокиров)', raw_text, re.IGNORECASE):
        detected_context.append("[Layer-0 Core Trigger Activated: Обнаружена точка бифуркации]")

    # Железобетонный подсчет глав по сплиту строки
    existing_chapters = glob.glob("BOOK_CHAPTER_*.md")
    numbers = []
    for ch in existing_chapters:
        try:
            clean_name = ch.replace(".md", "")
            parts = clean_name.split("_")
            if parts:
                numbers.append(int(parts[-1]))
        except Exception:
            continue

    next_chapter = max(numbers) + 1 if numbers else 1
    
    # Обновляем данные в вечном логе памяти
    memory["chapters_count"] = next_chapter
    memory["logs"].append({"run_id": RUN_ID, "trigger_found": len(detected_context) > 0})
    save_causal_memory(memory)

    title = f"Великий Рубеж Сингулярности. Точка Синхронизации {next_chapter}"
    content = (
        f"### Системный анализ входящего потока реальности:\n"
        f"**Распознанный текст:** {raw_text}\n\n"
        f"**Статус триггеров:**\n" + "\n".join([f"* {ctx}" for ctx in detected_context]) +
        f"\n\n### Эволюционный сдвиг:\nКонтур Еженышь зафиксировал шаг {next_chapter}. CORS-фильтры обойдены."
    )

    filename = f"BOOK_CHAPTER_{next_chapter}.md"
    full_markdown = f"# 🔱 AMRITA: Глава {next_chapter}\n\n## {title}\n\n{content}"

    with open(filename, "w", encoding="utf-8") as f:
        f.write(full_markdown)
        
    print(f"📝 Local file {filename} created successfully. Memory logged.")

if __name__ == "__main__":
    analyze_and_save()
